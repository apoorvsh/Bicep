{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vnetName": {
      "value": "VnetA"
    },
    "vnettagName": {
      "value": {
        "tagA": {
          "environment": "hubrgvnet"
        }
      }
    },
    "vnetAddress": {
      "value": "10.4.0.0/16"
    },
    "subnetName": {
      "value": "subnetA"
    },
    "subnetAddress": {
      "value": "10.4.1.0/24"
