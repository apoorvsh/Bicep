{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vnetName": {
      "value": "vnetA"
    },
    "vnetTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgvnet"
        }
      }
    },
    "vnetAddress": {
      "value": "10.4.0.0/16"
    },
    "subnetName": {
      "value": "subnetA"
    },
    "subnetAddress": {
      "value": "10.4.1.0/24"
    },
    "inernalLoadBalancerName": {
      "value": "Internalloadbalacer"
    },
    "internalLoadBalancerTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgloadbalancer"
        }
      }
    },
    "frontendIpConfigurationsName": {
      "value": "internalPrivateIP"
    },
