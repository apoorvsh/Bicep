{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "vnetName": {
      "value": "VNETA"
    },
    "vnetTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgvnet"
        }
      }
    },
    "vnetAddress": {
      "value": "10.5.0.0/16"
    },
    "subnetName": {
      "value": "SubnetA"
    },
    "subnetAddress": {
      "value": "10.5.1.0/24"
    },
    "nicName": {
      "value": "NIC1"
    },
    "windowNicTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgWindownic"
        }
      }
    },
    "nsgName": {
      "value": "WindowNSG"
    },
    "windowNsgTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgnsg"
        }
      }
    },
    "publicIpName": {
      "value": "WindowPublicIP"
    },
    "windowPulicIpTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgpublicipwindow"
        }
      }
    },
    "publicIpAllocationMethod": {
