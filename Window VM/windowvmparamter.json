      "value": "Inbound"
    },
    "storageProfilePublisher": {
      "value": "MicrosoftWindowsServer"
    },
    "storageProfileOffer": {
      "value": "WindowsServer"
    },
    "storageProfileSku": {
      "value": "2012-R2-Datacenter"
    },
    "storageProfileVersion": {
      "value": "latest"
    },
    "osDiskName": {
      "value": "WindoeVM1Disk"
    },
    "osDiskCaching": {
      "value": "ReadWrite"
