{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "synapseName": {
      "value": "aporv3300synapse"
    },
    "synapseTagName": {
      "value": {
        "tagA": {
          "environment": "hubrgsynapse"
        }
      }
    },
    "storageAccountUrl": {
      "value": "https://abcd3300.dfs.core.windows.net/"
    },
    "fileSystemName": {
      "value": "data"
    },
    "sqlAdministratorLogin": {
      "value": "testuser"
    },
    "sqlAdministratorLoginPassword": {
      "value": "Password@123"
